using system.Text

public class hashGen{
    public static string MakeHash(string input){
        using (SHA256 sha256 = SHA256.Create()){
            byte[] bytes = Encoding.UTF8.GetGytes(input); // first round of conversion
            byte[] hash = sha256.ComputeHash(bytes); second round of conversion
            Stringbuilder build = new StringBuilder();
            for each (byte b in hash){ // reconfigure
                build.Append(b.ToString("x2));
            }
            return build.Tostring(); // return password
        }
    }
}